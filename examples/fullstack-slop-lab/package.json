{
  "name": "nexusflow-slop-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "dev:api": ".venv/bin/python -m uvicorn backend.app:app --host 127.0.0.1 --port 8765 --reload",
    "build": "tsc --noEmit && vite build",
    "generate:openapi": ".venv/bin/python scripts/generate_openapi.py",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:api": ".venv/bin/python -m pytest -q tests",
    "verify:artifacts": ".venv/bin/python scripts/verify_artifacts.py"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
